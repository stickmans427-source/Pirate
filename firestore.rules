rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global Safety Net
    match /{document=**} { 
      allow read, write: if false; 
    }

    // --- PRIMITIVES ---
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }
    function isOwner() { return isSignedIn() && request.auth.token.email == 'stickmans427@gmail.com' && request.auth.token.email_verified == true; }

    // --- USER PROFILE ---
    function isValidUser(data) {
      return data.keys().hasAll(['username', 'email', 'role']) 
        && data.username is string && data.username.size() > 0 && data.username.size() <= 64
        && data.email is string && data.email.size() > 0
        && data.role in ['owner', 'user'];
    }

    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isOwner());
      allow list: if isSignedIn() && isOwner();
      allow create: if isSignedIn() && request.auth.uid == userId && isValidUser(incoming());
      allow update: if isSignedIn() && isValidUser(incoming()) && (
        isOwner() || 
        (request.auth.uid == userId && incoming().diff(existing()).affectedKeys().hasOnly([
          'username', 'avatarUrl', 'bio', 'purchasedAssets', 'favoritedAssets', 'lastDailyReward', 'tokens' // Tokens allowed for client updates like purchase/daily reward in this prototype
        ]))
      );
      allow delete: if isOwner();
    }

    // --- ASSETS ---
    function isValidAsset(data) {
      return data.keys().hasAll(['name', 'creatorId', 'uploadDate', 'price'])
        && data.name is string && data.name.size() > 0 && data.name.size() <= 128
        && data.creatorId is string && data.creatorId.size() > 0
        && data.price is number && data.price >= 0;
    }

    match /assets/{assetId} {
      allow get: if true;
      allow list: if true; // Global marketplace reads allow list queries
      allow create: if isSignedIn() && isValidAsset(incoming()) && incoming().creatorId == request.auth.uid;
      allow update: if isSignedIn() && isValidAsset(incoming()) && (
        isOwner() || 
        (existing().creatorId == request.auth.uid && incoming().creatorId == request.auth.uid) ||
        (incoming().diff(existing()).affectedKeys().hasOnly(['favoritesCount'])) // Anyone can favorite
      );
      allow delete: if isOwner() || (isSignedIn() && existing().creatorId == request.auth.uid);
    }

    // --- NOTIFICATIONS ---
    function isValidNotification(data) {
      return data.keys().hasAll(['userId', 'message', 'date', 'read'])
        && data.userId is string && data.userId.size() > 0;
    }

    match /notifications/{notificationId} {
      allow get: if isSignedIn() && (existing().userId == request.auth.uid || isOwner());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isOwner());
      allow create: if isSignedIn() && isValidNotification(incoming());
      allow update: if isSignedIn() && isValidNotification(incoming()) && (
        isOwner() || 
        (existing().userId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['read']))
      );
      allow delete: if isOwner() || (isSignedIn() && existing().userId == request.auth.uid);
    }
  }
}
